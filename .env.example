# DeploySense — Local Development Environment
#
# Copy this file to .env and fill in real values.
# Never commit .env to Git.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://deploysense:deploysense_dev@localhost:5432/deploysense
DATABASE_URL_SYNC=postgresql://deploysense:deploysense_dev@localhost:5432/deploysense

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
SECRET_KEY=dev-secret-key-change-in-production

# ─── GitHub OAuth ────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ─── Frontend ────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001

# ─── Services ────────────────────────────────────────────────────────────────
RISK_ENGINE_URL=http://localhost:8001

# ─── OpenTelemetry ───────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=deploysense
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_ENABLED=false

# ─── AI Engine (Phase 2) ────────────────────────────────────────────────────
# Supports any OpenAI-compatible endpoint:
#   OpenAI:   https://api.openai.com/v1
#   Gemini:   https://generativelanguage.googleapis.com/v1beta/openai
#   Ollama:   http://localhost:11434/v1
AI_API_BASE=https://api.openai.com/v1
AI_API_KEY=your-api-key-here
AI_MODEL=gpt-4o-mini
